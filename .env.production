# Production build defaults
# This file is loaded for `vite build` (and Cloudflare Pages production deploys).
# Setting maintenance here ensures https://training.tftiseasy.com/ shows the Coming Soon page
# during the development/pre-launch phase.
#
# When the app is ready for public launch:
#   - Change to VITE_MAINTENANCE_MODE=false
#   - Or remove the line (defaults to showing the full app)
#   - Commit + redeploy

VITE_MAINTENANCE_MODE=true
